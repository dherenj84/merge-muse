{
  "name": "merge-muse",
  "version": "0.1.0",
  "description": "Open-source self-hosted GitHub App that reviews merged PR titles and bodies against code changes and rewrites them using an LLM.",
  "license": "MIT",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "openapi:gen": "tsoa spec && node scripts/patch-openapi.mjs",
    "build": "npm run openapi:gen && tsc",
    "start": "node dist/index.js",
    "dev": "npm run openapi:gen && ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/app": "^15.1.0",
    "@octokit/rest": "^21.0.0",
    "@octokit/webhooks": "^13.3.0",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "lru-cache": "^11.0.0",
    "undici": "^8.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "tsoa": "^7.0.0-alpha.0",
    "typescript": "^5.5.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "setupFiles": [
      "<rootDir>/tests/setup.ts"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
