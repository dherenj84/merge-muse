# ── MergeMuse Configuration ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before starting the container.
# Lines starting with # are comments and are ignored.

# ── GitHub App Credentials ─────────────────────────────────────────────────────

# The numeric App ID shown on your GitHub App's settings page.
GITHUB_APP_ID=

# Private key for the GitHub App.
# Option A – inline PEM (replace newlines with literal \n):
# GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
#
# Option B – path to a PEM file on the host (mount it into the container):
# GITHUB_PRIVATE_KEY=@/run/secrets/github_private_key.pem
GITHUB_PRIVATE_KEY=

# Webhook secret configured in your GitHub App settings.
GITHUB_WEBHOOK_SECRET=

# ── LLM Provider ───────────────────────────────────────────────────────────────

# Base URL of your OpenAI-compatible endpoint (no trailing slash).
# Examples:
#   https://api.openai.com
#   http://ollama:11434
#   https://your-azure-openai.openai.azure.com/openai/deployments/my-model
LLM_BASE_URL=

# Model identifier. Must match what the endpoint accepts.
LLM_MODEL=gpt-4o-mini

# API key (use "ollama" for local Ollama; leave blank only if the endpoint is unauthenticated).
LLM_API_KEY=

# Timeout for each LLM request in milliseconds (default: 30000 = 30s).
# LLM_TIMEOUT_MS=30000

# Approximate max input tokens to send to the LLM per request (default: 8000).
# LLM_MAX_INPUT_TOKENS=8000

# Max tokens to allow in the LLM response (default: 512).
# LLM_MAX_OUTPUT_TOKENS=512

# ── Default Per-Repo Behaviour ─────────────────────────────────────────────────
# These values are used when a repo does not have a .mergemuse.yml file.

# Branch to watch for merges (default: main).
# DEFAULT_BASE_BRANCH=main

# What to do when a rewrite is ready:
#   patch    – update the PR title and body in place (default)
#   comment  – post a comment with the suggested rewrite
#   dry-run  – log the rewrite without touching the PR
# DEFAULT_ACTION_MODE=patch

# ── HTTP Server ─────────────────────────────────────────────────────────────────

# Port to listen on (default: 3000).
# PORT=3000

# Host/interface to bind to (default: 0.0.0.0).
# HOST=0.0.0.0

# ── Idempotency Cache ──────────────────────────────────────────────────────────

# Maximum number of delivery IDs to keep in the in-memory dedup cache (default: 1000).
# DEDUP_CACHE_MAX=1000

# TTL for each entry in milliseconds (default: 3600000 = 1 hour).
# DEDUP_CACHE_TTL_MS=3600000

# ── Diff Normaliser Limits ─────────────────────────────────────────────────────

# Maximum bytes of patch content per file before truncation (default: 50000).
# DIFF_MAX_FILE_BYTES=50000

# Maximum number of changed files to include in the LLM prompt (default: 100).
# DIFF_MAX_FILES=100

# ── GitHub Enterprise Server (GHES) ───────────────────────────────────────────

# Set this only if you are running against a GHES instance.
# Example: https://github.example.com/api/v3
# GITHUB_API_URL=

# ── Local End-To-End Mock Mode ───────────────────────────────────────────────

# When true, merged webhook events run through normalization, prompting,
# LLM call, and validation using synthetic PR/file data without fetching from
# GitHub APIs. Apply mode is forced to dry-run.
# LOCAL_MOCK_MODE=false
